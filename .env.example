# ==============================================================================
# AI Jobs Trends Tracker · 环境变量模板
# 复制为 .env 后填入真实值(.env 已 gitignore)
# ==============================================================================

# --- LLM APIs ---
# Anthropic Claude(抽取用 Haiku 4.5)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI(归一化用 text-embedding-3-small)
OPENAI_API_KEY=sk-xxx

# --- 数据库 ---
# 本地 SQLite 路径(默认值可留空)
DATABASE_URL=sqlite:///data/jobs.sqlite

# --- Fallback(Week 5+ 再启用) ---
# AWS Bedrock,Anthropic 宕机时切换
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-2

# --- 监控(Week 4+ 再启用) ---
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=ai-jobs-trends

# --- 运行模式 ---
# production / development
APP_ENV=development

# DEBUG 时只抽 N 条,避免烧 token
MAX_JOBS_PER_RUN=10
